# Azure AI Foundry Agent (default backend)
# FOUNDRY_ENDPOINT is the Foundry project endpoint. Provision via the
# src/000-cloud/085-ai-foundry component (see its ai_foundry_endpoint output).
FOUNDRY_ENDPOINT=<your-foundry-project-endpoint>
FOUNDRY_AGENT_ID=<your-foundry-agent-id>
AZURE_TENANT_ID=<your-tenant-id>
# FOUNDRY_MODEL_DEPLOYMENT is the model deployment name from 085-ai-foundry,
# used by `npm run provision:agent` to create/update the agent and emit FOUNDRY_AGENT_ID.
FOUNDRY_MODEL_DEPLOYMENT=<your-model-deployment-name>

# Factory ontology tool (query_factory_ontology)
# The agent's factory tool reads the static CORA/CORAX ontology from the
# RoboticsOntologyLH Fabric lakehouse (src/000-cloud/033-fabric-ontology).
# Provide either the explicit SQL endpoint host OR the workspace + lakehouse ids
# for host discovery via Fabric REST.
# RBAC prerequisite: the backend identity (DefaultAzureCredential) needs lakehouse
# read access; the SQL connection uses scope https://database.windows.net/.default.
FABRIC_WORKSPACE_ID=<your-fabric-workspace-id>
FABRIC_LAKEHOUSE_ID=<your-fabric-lakehouse-id>
# Optional explicit SQL host override (skips Fabric REST discovery)
# FABRIC_SQL_ENDPOINT=<your-lakehouse-sql-endpoint-host>
# Lakehouse SQL database name (default: RoboticsOntologyLH)
FABRIC_LAKEHOUSE_DATABASE=RoboticsOntologyLH

# Agent backend: "foundry" (default), "copilotstudio", or "directline"
AGENT_BACKEND=foundry

# Copilot Studio Direct Line (required when AGENT_BACKEND=directline)
DIRECT_LINE_SECRET=<your-copilot-studio-web-channel-secret>
# Optional: regional endpoint (default: https://directline.botframework.com)
# DIRECT_LINE_ENDPOINT=https://europe.directline.botframework.com

# Copilot Studio Agents SDK (required when AGENT_BACKEND=copilotstudio)
CPS_ENVIRONMENT_ID=<power-platform-environment-id>
CPS_AGENT_IDENTIFIER=<copilot-schema-name>
# Optional: Direct connect URL from Copilot Studio > Channels > Web app (overrides above)
# CPS_DIRECT_CONNECT_URL=

# OBO Token Exchange (required when AGENT_BACKEND=copilotstudio)
TEAMS_APP_CLIENT_SECRET=<client-secret-from-app-registration>

# Server
PORT=3978

# Teams SSO authentication
TEAMS_APP_ID=<your-teams-app-id>
# Comma-separated list of accepted token audiences (e.g. "<client-id>,api://<host>/<client-id>")
TEAMS_AUTH_AUDIENCES=<audience-1>,<audience-2>

# Auth control: set SKIP_AUTH=true for standalone local dev (loopback only) without Teams.
# Uncomment AUTH_REQUIRED=false ONLY for a Teams-less standalone/demo deployment
# (container or cluster) — it synthesizes a dev user for ALL requests, not just
# loopback (insecure, non-production). When unset or true, TEAMS_APP_ID and
# TEAMS_AUTH_AUDIENCES are required at startup.
# AUTH_REQUIRED=false
# SKIP_AUTH=true

# Azure Speech Services (for voice recognition — AAD auth, no key needed)
# Only required when using Azure speech (npm run build:client:azure)
# To use browser Web Speech API instead: npm run build:client:webspeech
AZURE_SPEECH_REGION=<your-speech-region>
AZURE_SPEECH_RESOURCE_ID=<your-speech-resource-name>

# Azure Voice Live (preview — Foundry resource)
# Server runtime reads VOICE_PROVIDER to decide whether to attach /api/voice-live bridge.
# Keep this in sync with the client bundle provider selected by npm scripts
# (build:client:* or start:* sets __SPEECH_PROVIDER__).
# Required when VOICE_PROVIDER=voicelive and client is built for voicelive.
# Auth: server-side DefaultAzureCredential (no key); identity needs "Cognitive Services User" on the resource
AZURE_VOICELIVE_RESOURCE=<your-voicelive-resource>
AZURE_VOICELIVE_MODEL=gpt-realtime
AZURE_VOICELIVE_API_VERSION=2025-10-01

# Voice provider selector (server runtime): "azure" (default), "webspeech", or "voicelive"
# Client provider is chosen at build time via __SPEECH_PROVIDER__.
VOICE_PROVIDER=azure
