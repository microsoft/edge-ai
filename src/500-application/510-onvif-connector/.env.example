# ONVIF Connector Development Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# ONVIF Camera Configuration
# =============================================================================
ONVIF_DEVICE_ID=onvif-camera-001
ONVIF_HOST=onvif-camera-simulator
ONVIF_PORT=8080

# Authentication (if using username/password mode)
ONVIF_USERNAME=admin
ONVIF_PASSWORD=admin123

# =============================================================================
# MQTT Broker Configuration
# =============================================================================
MQTT_BROKER=mosquitto-broker
MQTT_PORT=1883
MQTT_CLIENT_ID=onvif-connector-client
MQTT_TOPIC_PREFIX=onvif-camera

# MQTT Admin Credentials (for monitoring)
MQTT_ADMIN_USERNAME=admin
MQTT_ADMIN_PASSWORD=password123

# =============================================================================
# ONVIF Connector Settings
# =============================================================================
# Event polling interval in seconds (default: 5)
EVENT_POLL_INTERVAL=5

# PTZ movement speed (0.0 to 1.0)
PTZ_PAN_SPEED=0.5
PTZ_TILT_SPEED=0.5
PTZ_ZOOM_SPEED=0.3

# =============================================================================
# Development Settings
# =============================================================================
# Set to 'true' to enable debug logging
DEBUG_MODE=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# Camera Dashboard Configuration
# =============================================================================
# Comma-separated RTSP URLs for cameras to monitor
CAMERA_URLS=rtsp://admin:password@rtsp-camera-1:8554/live.sdp/pattern
# Comma-separated display names (must match CAMERA_URLS count)
CAMERA_NAMES=test-camera-1

# Dashboard web server settings
DASHBOARD_PORT=5001
DASHBOARD_HOST=0.0.0.0
VIDEO_FPS=15
JPEG_QUALITY=75
