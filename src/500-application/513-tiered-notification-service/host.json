{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    },
    "logLevel": {
      "default": "Information",
      "Host.Triggers.EventHub": "Warning"
    }
  },
  "extensions": {
    "eventHubs": {
      "maxEventBatchSize": 64,
      "prefetchCount": 128,
      "batchCheckpointFrequency": 1
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}
