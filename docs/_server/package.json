{
  "name": "edge-ai-progress-server",
  "version": "2.0.0",
  "type": "module",
  "description": "Express.js progress tracking server with SSE and schema validation",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "lint": "cd ../.. && npm run eslint:server",
    "lint:fix": "cd ../.. && npm run eslint:server -- --fix"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "chokidar": "^5.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.4",
    "eslint": "^10.2.0",
    "eventsource": "^4.0.0",
    "happy-dom": "^20.8.9",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.0.1",
    "supertest": "^7.1.4",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "license": "MIT",
  "keywords": [
    "express",
    "server",
    "progress-tracking",
    "sse",
    "api",
    "schema-validation"
  ],
  "overrides": {
    "flatted": "3.4.2"
  }
}
