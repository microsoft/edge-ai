          <mxGeometry x="10" y="305" width="100" height="30" as="geometry" />
        </mxCell>

        <!-- RTSP Stream Arrow -->
        <mxCell id="rtsp-arrow" value="RTSP Stream&#xa;rtsp://camera:554/stream1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#FF6B6B;fontSize=10;" edge="1" parent="1" source="camera" target="media-connector">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Media Connector Pod -->
