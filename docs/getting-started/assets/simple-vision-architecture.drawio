          <mxGeometry x="150" y="240" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="media-connector-details" value="• Captures frames&#xa;• 2s intervals&#xa;• 640x480 @ 85% quality" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;" vertex="1" parent="1">
