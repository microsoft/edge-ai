/*
 * Dataflow Graphs Configuration Example — Avro to JSON
 *
 * This file demonstrates how to configure the Kafka source endpoint and
 * dataflow graph that uses the avro-to-json WASM module to transform Avro
 * binary messages from a Kafka broker to JSON on an MQTT topic.
 *
 * Before applying this configuration, build and push the module from
 * src/500-application/512-avro-to-json:
 *   ./scripts/build-wasm.sh
 *   ./scripts/push-to-acr.sh <acr_name>
 *
 * Copy the contents to enrich your terraform.tfvars with these values.
 * Ensure your terraform.tfvars also includes the required core variables, for example:
 *
 *   environment                          = "graphs"
 *   resource_prefix                      = "avro"
 *   location                             = "eastus2"
 *   instance                             = "001"
 *   should_include_acr_registry_endpoint = true
 */

// Step 1: Configure the Kafka broker as a DataflowEndpoint.
// Replace the host with your Kafka broker address.
// See: https://learn.microsoft.com/azure/iot-operations/connect-to-cloud/howto-configure-kafka-endpoint?tabs=portal
dataflow_endpoints = [
  {
    name         = "kafka-source"
    endpointType = "Kafka"
    kafkaSettings = {
      // Replace with your Kafka broker host and port, and authentication method
      host = "broker.example.com:9093"
      authentication = {
        method                                = "SystemAssignedManagedIdentity"
        systemAssignedManagedIdentitySettings = {}
      }
      tls = {
        mode = "Enabled"
      }
      consumerGroupId = "aio-avro-to-json"
    }
  }
]

// Step 2: Configure the dataflow graph that wires the Kafka source through
// the avro-to-json WASM module to the default MQTT broker endpoint.
dataflow_graphs = [
  {
    name = "equipment-telemetry-avro-to-json"
    nodes = [
      {
        nodeType = "Source"
        name     = "kafka-avro-source"
        sourceSettings = {
          // Must match the DataflowEndpoint name defined in dataflow_endpoints above
          endpointRef = "kafka-source"
          // Replace with the Kafka topic that carries Avro-encoded messages
          dataSources = ["equipment.telemetry.avro"]
        }
      },
      {
        nodeType = "Graph"
        name     = "avro-to-json-map"
        graphSettings = {
          // Must match the registry endpoint name: acr-{var.resource_prefix}
          registryEndpointRef = "acr-avro"
          artifact            = "avro-to-json-graph:1.0.0"
          // avroSchema is required only when messages are raw Avro binary
          // (no embedded schema). Omit this configuration block entirely
          // when the producer sends Object Container File (OCF) format,
          // which carries the schema in the message header.
          configuration = [
            {
              key = "avroSchema"
              value = <<-EOF
                {
                  "type": "record",
                  "name": "EquipmentTelemetry",
                  "namespace": "com.contoso.manufacturing",
                  "doc": "Equipment sensor telemetry from process manufacturing line",
                  "fields": [
                    { "name": "equipmentId", "type": "string", "doc": "Unique identifier for the equipment" },
                    {
                      "name": "sensorType",
                      "type": {
                        "type": "enum",
                        "name": "SensorType",
                        "symbols": ["TEMPERATURE", "PRESSURE", "VIBRATION", "FLOW_RATE"]
                      },
                      "doc": "Type of sensor reading"
                    },
                    { "name": "value", "type": "double", "doc": "Sensor reading value" },
                    { "name": "unit", "type": "string", "doc": "Unit of measurement (e.g., celsius, bar, mm_s, l_min)" },
                    { "name": "timestamp", "type": "long", "doc": "Unix timestamp in milliseconds" },
                    { "name": "qualityCode", "type": ["null", "int"], "default": null, "doc": "OPC UA quality code, null if not available" },
                    {
                      "name": "location",
                      "type": {
                        "type": "record",
                        "name": "Location",
                        "fields": [
                          { "name": "plant", "type": "string", "doc": "Plant identifier" },
                          { "name": "line", "type": "string", "doc": "Production line" },
                          { "name": "station", "type": "string", "doc": "Work station" }
                        ]
                      },
                      "doc": "Physical location of the equipment"
                    }
                  ]
                }
              EOF
            }
          ]
        }
      },
      {
        nodeType = "Destination"
        name     = "mqtt-json-destination"
        destinationSettings = {
          endpointRef     = "default"
          dataDestination = "equipment/telemetry/json"
        }
      }
    ]
    node_connections = [
      {
        from = { name = "kafka-avro-source" }
        to   = { name = "avro-to-json-map" }
      },
      {
        from = { name = "avro-to-json-map" }
        to   = { name = "mqtt-json-destination" }
      }
    ]
  }
]
