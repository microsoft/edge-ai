/*
 * Dataflow Graphs Configuration Example — Message to DSS (Write and Optional Enrich)
 *
 * This file demonstrates the two complementary operators packaged in
 * src/500-application/514-wasm-msg-to-dss:
 *
 *   Pipeline A (write):  msg-to-dss-key writes any JSON message from an MQTT
 *                        topic to the AIO Distributed State Store (DSS) under a
 *                        configurable key, passing the message through unchanged.
 *   Pipeline B (enrich): dss-enricher-key reads a stored record from the DSS
 *                        using a key built from the incoming message and merges
 *                        selected fields into the outgoing message.
 *
 * Pipeline B is OPTIONAL. Keep only Pipeline A in dataflow_graphs if you just
 * need to write state to the DSS. Add Pipeline B when a downstream pipeline must
 * enrich messages with that stored state using a dynamically constructed key.
 *
 * Before applying this configuration, build and push both operators from
 * src/500-application/514-wasm-msg-to-dss:
 *   ./scripts/build-wasm.sh
 *   ./scripts/push-to-acr.sh <acr_name>
 *
 * Copy the contents to enrich your terraform.tfvars with these values.
 * Ensure your terraform.tfvars also includes the required core variables, for example:
 *
 *   environment                          = "graphs"
 *   resource_prefix                      = "dss"
 *   location                             = "eastus2"
 *   instance                             = "001"
 *   should_include_acr_registry_endpoint = true
 */

// Configure two dataflow graphs:
//   Pipeline A wires the default MQTT source through the msg-to-dss-key WASM
//     module back to a destination MQTT topic. The operator writes each message
//     to the DSS and forwards it unchanged.
//   Pipeline B (optional) wires a telemetry source through the dss-enricher-key
//     WASM module, reading state written by Pipeline A and merging it into the
//     outgoing message. Remove this second object to deploy the write side only.
dataflow_graphs = [
  # Pipeline A: Write device state to DSS
  {
    name = "device-state-to-dss"
    nodes = [
      {
        nodeType = "Source"
        name     = "mqtt-source"
        sourceSettings = {
          // Read from the default AIO MQTT broker endpoint
          endpointRef = "default"
          // Replace with the MQTT topic carrying JSON messages to index in the DSS
          dataSources = ["devices/+/state"]
        }
      },
      {
        nodeType = "Graph"
        name     = "msg-to-dss-key-map"
        graphSettings = {
          // Must match the registry endpoint name: acr-{var.resource_prefix}
          registryEndpointRef = "acr-dss"
          artifact            = "msg-to-dss-key-graph:1.0.0"
          // Configure key extraction and TTL for the state store write.
          // keyPath (required): JSON Pointer to the field used as the state store key.
          // ttlSeconds (required): TTL in seconds (0 = no expiration).
          // keyPrefix (optional): Prefix for namespace isolation.
          // onMissing (optional): "skip" (default) or "error".
          configuration = [
            {
              key   = "keyPath"
              value = "/deviceId"
            },
            {
              key   = "keyPrefix"
              value = "device:"
            },
            {
              key   = "ttlSeconds"
              value = "86400"    # 24 hours
            }
          ]
        }
      },
      {
        nodeType = "Destination"
        name     = "mqtt-destination"
        destinationSettings = {
          // Write the passthrough message to a processed MQTT topic
          endpointRef     = "default"
          dataDestination = "devices/state/processed"
        }
      }
    ]
    node_connections = [
      {
        from = { name = "mqtt-source" }
        to   = { name = "msg-to-dss-key-map" }
      },
      {
        from = { name = "msg-to-dss-key-map" }
        to   = { name = "mqtt-destination" }
      }
    ]
  },

  # Pipeline B (OPTIONAL): Enrich telemetry with stored device state.
  # Remove this object to deploy the write side only.
  {
    name = "telemetry-enrichment"
    nodes = [
      {
        nodeType = "Source"
        name     = "telemetry-source"
        sourceSettings = {
          endpointRef = "default"
          // Replace with the MQTT topic carrying telemetry to enrich
          dataSources = ["telemetry/+/readings"]
        }
      },
      {
        nodeType = "Graph"
        name     = "dss-enricher-key-map"
        graphSettings = {
          // Must match the registry endpoint name: acr-{var.resource_prefix}
          registryEndpointRef = "acr-dss"
          artifact            = "dss-enricher-key-graph:1.0.0"
          // Configure the DSS lookup and field merge.
          // keyPath (required): JSON Pointer to the field used as the lookup key.
          // keyPrefix (optional): Prefix matching the write side namespace.
          // outputPath (optional): JSON path where enriched data is injected.
          // fields (optional): Comma-separated fields to extract ("*" = all).
          // onMissing (optional): "skip" (default), "error", or "default".
          // Use the same keyPath and keyPrefix as Pipeline A to read its writes.
          configuration = [
            {
              key   = "keyPath"
              value = "/deviceId"
            },
            {
              key   = "keyPrefix"
              value = "device:"
            },
            {
              key   = "outputPath"
              value = "deviceContext"
            },
            {
              key   = "fields"
              value = "location,calibration,name"
            },
            {
              key   = "onMissing"
              value = "skip"
            }
          ]
        }
      },
      {
        nodeType = "Destination"
        name     = "enriched-destination"
        destinationSettings = {
          endpointRef     = "default"
          dataDestination = "telemetry/enriched"
        }
      }
    ]
    node_connections = [
      {
        from = { name = "telemetry-source" }
        to   = { name = "dss-enricher-key-map" }
      },
      {
        from = { name = "dss-enricher-key-map" }
        to   = { name = "enriched-destination" }
      }
    ]
  }
]

// --- Additional Configuration Examples ---
//
// Pipeline A (write) — nested key extraction:
//
//   configuration = [
//     { key = "keyPath",    value = "/metadata/entityId" },
//     { key = "keyPrefix",  value = "entity:" },
//     { key = "ttlSeconds", value = "3600" }
//   ]
//
// Pipeline A (write) — array-indexed key:
//
//   configuration = [
//     { key = "keyPath",    value = "/entries/0/id" },
//     { key = "keyPrefix",  value = "entry:" },
//     { key = "ttlSeconds", value = "86400" }
//   ]
//
// Pipeline A (write) — no expiration with strict missing-key behavior:
//
//   configuration = [
//     { key = "keyPath",    value = "/assetId" },
//     { key = "keyPrefix",  value = "asset:" },
//     { key = "ttlSeconds", value = "0" },
//     { key = "onMissing",  value = "error" }
//   ]
//
// Pipeline B (enrich) — merge all stored fields at the message root:
//
//   configuration = [
//     { key = "keyPath",   value = "/deviceId" },
//     { key = "keyPrefix", value = "device:" }
//   ]
//
// Pipeline B (enrich) — strict mode that drops messages without matching state:
//
//   configuration = [
//     { key = "keyPath",   value = "/deviceId" },
//     { key = "keyPrefix", value = "device:" },
//     { key = "onMissing", value = "error" }
//   ]
