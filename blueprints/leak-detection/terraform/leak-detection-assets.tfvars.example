// Leak detection SSE camera device and event asset definitions.
// Copy these values into your .tfvars file or terraform.tfvars.
should_enable_akri_media_connector = true
should_enable_akri_onvif_connector = true

namespaced_devices = [
  {
    name    = "pipe"
    enabled = true
    endpoints = {
      outbound = { assigned = {} }
      inbound = {
        "pipe-stream" = {
          endpoint_type = "Custom"
          address       = "rtsp://onvif-camera-simulator:8554/cam1"  # ← Update with your RTSP URL
          authentication = {
            method = "Anonymous"  // For development/testing only
          }
          trustSettings = null
        }
      }
    }
  }
]

namespaced_assets = [
  {
    name         = "pipe-snapshots"
    display_name = "Pipe Snapshots"
    device_ref = {
      device_name   = "pipe"
      endpoint_name = "pipe-stream"
    }
    enabled = true
    datasets = [
      {
        name = "snapshots"
        dataset_configuration = "{\"taskType\":\"snapshot-to-mqtt\",\"intervalSeconds\":5,\"quality\":75,\"width\":640,\"height\":480}"
        destinations = [{ target = "Mqtt", configuration = { topic = "edge-ai/test/pipe/camera/snapshots" } }]
        data_points = []
        data_source = ""
      }
    ]
  }
]
