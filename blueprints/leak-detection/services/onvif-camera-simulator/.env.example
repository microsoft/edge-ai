# Camera definitions (comma-separated camera IDs)
CAMERAS=cam1

# Per-camera configuration (pattern type works without media files)
CAM1_NAME=Test Pattern
CAM1_SOURCE=testsrc
CAM1_TYPE=pattern
CAM1_RESOLUTION=640x480
CAM1_FRAMERATE=5

# Media file camera (requires file in /data volume)
# CAM1_NAME=Pipeline North Camera
# CAM1_SOURCE=/data/pipeline-north.jpg
# CAM1_TYPE=jpeg
# CAM1_RESOLUTION=640x480
# CAM1_FRAMERATE=5

# CAM2_NAME=Pipeline South Camera
# CAM2_SOURCE=/data/pipeline-south.mp4
# CAM2_TYPE=mp4

# Server configuration
ONVIF_PORT=8080
MEDIAMTX_RTSP_PORT=8554
DEVICE_HOSTNAME=localhost
LOG_LEVEL=INFO
MEDIA_DIR=/data

# WebRTC preview (stream preview in the Web UI)
# Port 8189 must be reachable from the browser for WebRTC media transport.
# Set MTX_WEBRTCADDITIONALHOSTS to the externally-reachable hostname/IP when
# running in Docker or Kubernetes (defaults to DEVICE_HOSTNAME).
WEBRTC_MEDIA_PORT=8189
# MTX_WEBRTCADDITIONALHOSTS=192.168.1.100
