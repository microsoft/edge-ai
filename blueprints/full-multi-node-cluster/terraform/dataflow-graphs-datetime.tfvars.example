/*
 * Dataflow Graphs Configuration Example - Lot Age Datetime Pipeline
 *
 * This file demonstrates how to configure a dataflow graph that chains the
 * datetime WASM module across multiple Graph nodes to enrich a food
 * manufacturing lot traceability event with derived datetime fields: the lot
 * age in minutes and in hours, plus a normalized display timestamp, while
 * passing the message through to a destination MQTT topic.
 *
 * It extends the lot traceability use case in
 * src/500-application/514-wasm-msg-to-dss (Pipeline A writes lot metadata to the
 * DSS, Pipeline B enriches a packaging event with the stored lot fields,
 * including completedAt). The packaging event already carries startedAt, so the
 * enriched message holds both timestamps this pipeline needs.
 *
 * Before applying this configuration, build and push the module from
 * src/500-application/515-wasm-expressions:
 *   ./scripts/build-wasm.sh
 *   ./scripts/push-to-acr.sh <acr_name>
 *
 * Copy the contents to enrich your terraform.tfvars with these values.
 * Ensure your terraform.tfvars also includes the required core variables, for example:
 *
 *   environment                          = "graphs"
 *   resource_prefix                      = "dt"
 *   location                             = "eastus2"
 *   instance                             = "001"
 *   should_include_acr_registry_endpoint = true
 */

// Configure the dataflow graph that wires the enriched packaging event through
// three chained datetime WASM nodes (duration minutes -> duration hours ->
// reformat) back to a destination MQTT topic. Each node performs one mode and
// adds one derived field by JSON Pointer; the message is forwarded unchanged
// downstream.
dataflow_graphs = [
  {
    name = "lot-age-from-packaging"
    nodes = [
      {
        nodeType = "Source"
        name     = "lot-source"
        sourceSettings = {
          // Read from the default AIO MQTT broker endpoint
          endpointRef = "default"
          // Enriched packaging events carrying both startedAt and the lot's completedAt
          dataSources = ["packaging/started"]
        }
      },
      {
        nodeType = "Graph"
        name     = "datetime-age-minutes"
        graphSettings = {
          // Must match the registry endpoint name: acr-{var.resource_prefix}
          registryEndpointRef = "acr-dt"
          artifact            = "datetime-graph:1.0.0"
          // duration mode: lot age = startedAt - completedAt, in minutes.
          // mode (required): "duration".
          // inputPath (required): JSON Pointer to the first (later) timestamp.
          // inputPath2 (required): JSON Pointer to the second (earlier) timestamp.
          // outputPath (required): JSON Pointer where the duration is written.
          // unit (optional): "ms" (default), "seconds", "minutes", "hours".
          // onMissing (optional): "skip" (default) or "error".
          configuration = [
            { key = "mode", value = "duration" },
            { key = "inputPath", value = "/startedAt" },
            { key = "inputPath2", value = "/completedAt" },
            { key = "outputPath", value = "/lotAgeMinutes" },
            { key = "unit", value = "minutes" },
            { key = "onMissing", value = "skip" }
          ]
        }
      },
      {
        nodeType = "Graph"
        name     = "datetime-age-hours"
        graphSettings = {
          // Must match the registry endpoint name: acr-{var.resource_prefix}
          registryEndpointRef = "acr-dt"
          artifact            = "datetime-graph:1.0.0"
          // duration mode: lot age = startedAt - completedAt, in hours.
          configuration = [
            { key = "mode", value = "duration" },
            { key = "inputPath", value = "/startedAt" },
            { key = "inputPath2", value = "/completedAt" },
            { key = "outputPath", value = "/lotAgeHours" },
            { key = "unit", value = "hours" },
            { key = "onMissing", value = "skip" }
          ]
        }
      },
      {
        nodeType = "Graph"
        name     = "datetime-completed-display"
        graphSettings = {
          // Must match the registry endpoint name: acr-{var.resource_prefix}
          registryEndpointRef = "acr-dt"
          artifact            = "datetime-graph:1.0.0"
          // reformat mode: rewrite completedAt into a human-readable layout.
          // mode (required): "reformat".
          // inputPath (required): JSON Pointer to the source timestamp.
          // outputPath (required): JSON Pointer where the display string is written.
          // format (required): strftime-style layout for the output string.
          // onMissing (optional): "skip" (default) or "error".
          configuration = [
            { key = "mode", value = "reformat" },
            { key = "inputPath", value = "/completedAt" },
            { key = "outputPath", value = "/completedDisplay" },
            { key = "format", value = "%Y-%m-%d %H:%M" },
            { key = "onMissing", value = "skip" }
          ]
        }
      },
      {
        nodeType = "Destination"
        name     = "lot-destination"
        destinationSettings = {
          // Write the aged traceability record to a processed MQTT topic
          endpointRef     = "default"
          dataDestination = "traceability/lot-aged"
        }
      }
    ]
    node_connections = [
      {
        from = { name = "lot-source" }
        to   = { name = "datetime-age-minutes" }
      },
      {
        from = { name = "datetime-age-minutes" }
        to   = { name = "datetime-age-hours" }
      },
      {
        from = { name = "datetime-age-hours" }
        to   = { name = "datetime-completed-display" }
      },
      {
        from = { name = "datetime-completed-display" }
        to   = { name = "lot-destination" }
      }
    ]
  }
]

// --- Downstream Built-in Map Hand-Off ---
//
// When numeric math is preferred over the duration mode, a parse-mode node emits
// epoch fields (for example /startedEpochMs and /completedEpochMs) that
// downstream built-in dataflow expressions can consume directly. A built-in
// `map` transformation computes a numeric difference without any WASM module:
//
//   lotAgeMs = $1 - $2
//
// where $1 = /startedEpochMs and $2 = /completedEpochMs. Wire the built-in map
// after a datetime-parse node (or as a further graph branch) to perform epoch
// math, then round or scale the result with built-in functions such as
// round_n(...) exactly as a numeric pipeline does today.
//
// --- Additional Configuration Examples ---
//
// Lot age in seconds with strict missing-key behavior:
//
//   configuration = [
//     { key = "mode",       value = "duration" },
//     { key = "inputPath",  value = "/startedAt" },
//     { key = "inputPath2", value = "/completedAt" },
//     { key = "outputPath", value = "/lotAgeSeconds" },
//     { key = "unit",       value = "seconds" },
//     { key = "onMissing",  value = "error" }
//   ]
//
// Parse completedAt to epoch milliseconds for downstream numeric math:
//
//   configuration = [
//     { key = "mode",       value = "parse" },
//     { key = "inputPath",  value = "/completedAt" },
//     { key = "outputPath", value = "/completedEpochMs" },
//     { key = "epochUnit",  value = "ms" }
//   ]
